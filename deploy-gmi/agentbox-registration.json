{
  "project_name": "amcp-agent",
  "deployment_path": "GMI CE Deployment",
  "docker": {
    "build_context": ".",
    "dockerfile": "deploy-gmi/Dockerfile",
    "local_image": "amcp-gmi:latest",
    "build_command": "docker build -f deploy-gmi/Dockerfile -t amcp-gmi:latest .",
    "registry_url": "ghcr.io/tao12345666333/amcp:gmi-0.11.0"
  },
  "infrastructure": {
    "compute_tier": "Container, 2 vCPU, 4 GB RAM, 10 GiB ephemeral storage, 30 GiB data storage",
    "region": "IOWA IDC-1 (US-IA, US)",
    "maas_integration": true,
    "models": [
      "<select one or more GMI MaaS models in the GMI dashboard>"
    ]
  },
  "networking": {
    "protocol": "HTTPS/2",
    "listening_port": 443,
    "internal_port": 8080,
    "port_name": "web",
    "health_check_path": "/api/v1/health",
    "openapi_path": "/docs"
  },
  "gmi_auto_injected_env": [
    "GMI_MAAS_BASE_URL",
    "GMI_MAAS_API_KEY",
    "GMI_MODELS"
  ],
  "custom_env": [
    {
      "name": "AMCP_WORK_DIR",
      "type": "TEXT",
      "value": "/workspace"
    },
    {
      "name": "AMCP_GMI_REWRITE_CONFIG",
      "type": "TEXT",
      "value": "0"
    },
    {
      "name": "AMCP_CHAT_MODEL",
      "type": "TEXT",
      "value": "<optional primary GMI MaaS model>"
    }
  ],
  "endpoint_smoke_tests": [
    "curl -fsS https://<gmi-public-url>/api/v1/health",
    "curl -fsS https://<gmi-public-url>/api/v1/info"
  ]
}
